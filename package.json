{
  "publisher": "mleon",
  "name": "vscode-whisper-dictation",
  "displayName": "Voice Dictation",
  "description": "Local voice dictation with Whisper. No internet, no APIs. Records, transcribes and copies to clipboard.",
  "version": "1.5.0",
  "icon": "Logo.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": ["dictation", "voice", "whisper", "speech-to-text", "transcription"],
  "author": "Manuel León",
  "contributors": [
    { "name": "Claude (Anthropic)", "url": "https://claude.ai" }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mleonmendiola-ionos/vscode-whisper-dictation"
  },
  "license": "MIT",
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "whisper-dictation.toggle",
        "title": "Dictation: Open voice panel",
        "icon": "$(mic)"
      },
      {
        "command": "whisper-dictation.toggleRecording",
        "title": "Dictation: Start/stop recording",
        "icon": "$(record)"
      }
    ],
    "keybindings": [
      {
        "command": "whisper-dictation.toggle",
        "key": "ctrl+shift+v"
      },
      {
        "command": "whisper-dictation.toggleRecording",
        "key": "ctrl+shift+r",
        "when": "whisperDictation.panelVisible"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "whisper-dictation.toggle",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Voice Dictation",
      "properties": {
        "whisper-dictation.model": {
          "type": "string",
          "default": "small",
          "enum": ["tiny", "base", "small", "medium", "large-v3"],
          "enumDescriptions": [
            "Tiny (~75 MB, fastest loading, lower accuracy)",
            "Base (~145 MB, fast loading, good accuracy)",
            "Small (~480 MB, balanced speed and accuracy)",
            "Medium (~1.5 GB, slower loading, high accuracy)",
            "Large v3 (~3 GB, slowest loading, best accuracy)"
          ],
          "description": "Whisper model size. Smaller models load faster but are less accurate."
        },
        "whisper-dictation.language": {
          "type": "string",
          "default": "es",
          "description": "Language code for transcription (e.g. es, en, de)"
        },
        "whisper-dictation.device": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "cpu", "cuda"],
          "enumDescriptions": [
            "Auto-detect: use GPU if available, otherwise CPU",
            "CPU only (slower but always works)",
            "GPU with CUDA (much faster, requires NVIDIA GPU and CUDA drivers)"
          ],
          "description": "Inference device for the Whisper model"
        },
        "whisper-dictation.maxRecordingSeconds": {
          "type": "number",
          "default": 300,
          "minimum": 10,
          "maximum": 3600,
          "description": "Maximum recording duration in seconds. Recording stops automatically after this time (default: 300 = 5 minutes)."
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --format=cjs --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --format=cjs --watch",
    "package": "npm run build && vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.0.0"
  }
}
